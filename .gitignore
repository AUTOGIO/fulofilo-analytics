# FulôFiló Analytics Pro — .gitignore
# ──────────────────────────────────────

# Virtual environment
.venv/

# DuckDB WAL (transient, not the db itself)
data/fulofilo.duckdb.wal

# NOTE: data/fulofilo.duckdb and data/parquet/ are intentionally tracked
# so Streamlit Cloud can load them without a separate ETL step.

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# IDE / Editor
.cursor/
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Logs
logs/
*.log

# Generated Excel reports (keep template, not dated outputs)
excel/FuloFilo_Report_*.xlsx

# YOLO training runs (large binary artifacts)
visual_pos/runs/

# Visual reconciliation generated artifacts
data/source_catalog/
data/raw_checkout/
data/synthetic/
data/splits/
data/outputs/
data/models/
data/backgrounds/
data/manifests/catalog_manifest.csv
data/manifests/catalog_manifest.json
data/manifests/scene_manifest.csv
data/manifests/split_manifest.csv

# uv lock (reproducible via pyproject.toml)
uv.lock

# Secrets / env files
.env
.env.*
secrets/

# Temporary files
tmp/
*.tmp
*.bak
