# FulôFiló Analytics Pro — .gitignore
# ──────────────────────────────────────

# Virtual environment
.venv/

# DuckDB database (runtime artifact, regenerated by ETL)
data/fulofilo.duckdb
data/fulofilo.duckdb.wal

# Parquet files (generated artifacts)
data/parquet/

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# IDE / Editor
.cursor/
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Logs
logs/
*.log

# Generated Excel reports (keep template, not dated outputs)
excel/FuloFilo_Report_*.xlsx

# YOLO training runs (large binary artifacts)
visual_pos/runs/

# uv lock (reproducible via pyproject.toml)
uv.lock

# Secrets / env files
.env
.env.*
secrets/

# Temporary files
tmp/
*.tmp
*.bak
