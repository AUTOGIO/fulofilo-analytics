# FulôFiló Analytics Pro — .gitignore
# ──────────────────────────────────────

# ── Python ─────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
build/
dist/

# ── Virtualenvs / package caches ───────
.venv/
venv/
.uv-cache/
uv.lock

# ── Test / tooling caches ──────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ── Node (Cloudflare worker) ───────────
cf-worker/node_modules/
cf-worker/.wrangler/
node_modules/

# ── Editors / IDEs ─────────────────────
.vscode/
.idea/
.cursor/
.claude/
*.swp
*.swo
*~

# ── OS noise ───────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ── Logs ───────────────────────────────
logs/
*.log

# ── Secrets / env ──────────────────────
.env
.env.*
!.env.example
!.env.*.example
secrets/
*.pem
*.key

# ── Temporary / scratch ────────────────
tmp/
.tmp/
*.tmp
*.bak
*.orig

# ── Generated reports / exports ────────
excel/FuloFilo_Report_*.xlsx
FuloFilo_Report_*.xlsx
reports/*.tmp.xlsx
sales_automation_bundle.zip

# ── DuckDB transients (keep the .duckdb file) ──
data/fulofilo.duckdb.wal

# ── Visual POS (YOLO) — large binary artifacts ──
visual_pos/runs/
data/source_catalog/
data/raw_checkout/
data/synthetic/
data/splits/
data/outputs/
data/models/
data/backgrounds/
data/manifests/catalog_manifest.csv
data/manifests/catalog_manifest.json
data/manifests/scene_manifest.csv
data/manifests/split_manifest.csv

# NOTE: data/fulofilo.duckdb and data/parquet/ are intentionally tracked
# so Streamlit Cloud can load them without a separate ETL step.
