# Cloudflare credentials for the cf-worker deployment.
# Copy this file to `.env.cloudflare` (gitignored) and fill in real values.
# Never commit the populated file. Rotate tokens in the Cloudflare dashboard
# if a secret is ever exposed.

# API token with permissions: Account → Workers Scripts: Edit
CLOUDFLARE_API_TOKEN=

# Optional: account/zone IDs if your deploy scripts need them
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ZONE_ID=
